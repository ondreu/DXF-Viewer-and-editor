{
  "name": "obsidian-dxf-viewer-editor",
  "version": "0.9.1",
  "description": "View and lightly edit DXF drawings inside Obsidian, on desktop and mobile.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "check": "tsc -noEmit -skipLibCheck && svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint src --ext .ts",
    "test": "vitest run"
  },
  "keywords": [
    "obsidian",
    "dxf",
    "cad",
    "viewer"
  ],
  "author": "ondreu",
  "license": "MIT",
  "devDependencies": {
    "@tsconfig/svelte": "^5.0.4",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.20.0",
    "esbuild-svelte": "^0.8.1",
    "eslint": "^8.57.0",
    "obsidian": "^1.5.7",
    "svelte": "^4.2.12",
    "svelte-check": "^3.6.7",
    "svelte-preprocess": "^5.1.3",
    "tslib": "^2.6.2",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "dependencies": {
    "dxf-parser": "^1.1.2",
    "three": "^0.162.0",
    "@types/three": "^0.162.0"
  }
}
